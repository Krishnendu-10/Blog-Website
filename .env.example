# Copy this file to .env and fill in your values
# NEVER commit the real .env to Git

# Your Google Apps Script Web App URL (paste after deploying Code.gs)
VITE_GAS_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# URL of the AI image proxy backend
# Local development:
VITE_BACKEND_URL=http://localhost:5000
# Production (replace with your Render.com URL after deploying server.js):
# VITE_BACKEND_URL=https://your-app-name.onrender.com

# ImgBB image hosting — 100% free, no credit card needed
# 1. Sign up free at https://imgbb.com
# 2. Go to https://api.imgbb.com/ → click "Get API key"
# 3. Paste the key below
VITE_IMGBB_API_KEY=your_imgbb_api_key_here


